{
    "name": "bookreader-frontend",
    "private": true,
    "version": "0.1.1",
    "type": "module",
    "scripts": {
        "dev": "vite --host 127.0.0.1 --port 5174 --strictPort",
        "build": "vite build",
        "build:desktop": "vite build --configLoader runner",
        "test": "vitest run",
        "test:watch": "vitest",
        "preview": "vite preview --host 127.0.0.1 --port 5174 --strictPort",
        "tauri": "node scripts/tauri-cli.cjs",
        "desktop:dev": "node scripts/tauri-wrapper.cjs dev --dev-backend-python",
        "desktop:build": "npm run tauri -- build",
        "desktop:info": "npm run tauri -- info",
        "desktop:sidecar": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\backend\\build_sidecar.ps1",
        "desktop:preflight": "npm run desktop:info && npm run build:desktop && npm run desktop:build",
        "perf:report": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\collect-build-metrics.ps1",
        "perf:report:web": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\collect-build-metrics.ps1 -SkipDesktopSidecar",
        "perf:report:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\collect-build-metrics.ps1 -SkipWebBuild"
    },
    "dependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^7.3.0"
    },
    "devDependencies": {
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@tauri-apps/cli": "^2.10.0",
        "@vitejs/plugin-react": "^4.3.0",
        "autoprefixer": "^10.4.24",
        "jsdom": "^26.1.0",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.19",
        "vite": "^6.2.0",
        "vitest": "^2.1.8"
    }
}
