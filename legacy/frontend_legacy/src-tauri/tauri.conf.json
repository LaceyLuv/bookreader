{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BookReader",
  "version": "0.1.0",
  "identifier": "com.bookreader.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BookReader",
        "width": 800,
        "height": 600,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset:",
        "img-src": "'self' asset: data: http://127.0.0.1:8000 http://localhost:8000",
        "connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:8000 http://localhost:8000"
      }
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/bookreader-backend"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
